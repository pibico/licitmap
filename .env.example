# LicitMap — configuración de entorno
# Copiar a `.env` y ajustar. NO commitear el `.env` real.

# Conexión a PostgreSQL
DATABASE_URL=postgresql://licitmap:licitmap@localhost:5432/licitmap

# Clave para firmar cookies de sesión (generar con: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=cambia-esto-en-produccion

# Años de histórico a mantener en BD (la purga diaria borra licitaciones con fecha_limite anterior)
HISTORY_YEARS=5
